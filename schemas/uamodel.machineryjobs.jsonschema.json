{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opcfoundation.org/schemas/UA/Machinery/Jobs/types.json",
  "$defs": {
    "JobExecutionMode": {
      "anyOf": [
        {
          "const": 0,
          "title": "SimulationMode"
        },
        {
          "const": 1,
          "title": "TestMode"
        },
        {
          "const": 2,
          "title": "ProductionMode"
        }
      ]
    },
    "ProcessIrregularity": {
      "anyOf": [
        {
          "const": 0,
          "title": "CapabilityUnavailable"
        },
        {
          "const": 1,
          "title": "Detected"
        },
        {
          "const": 2,
          "title": "NotDetected"
        },
        {
          "const": 3,
          "title": "NotYetDetermined"
        }
      ]
    },
    "JobResult": {
      "anyOf": [
        {
          "const": 0,
          "title": "Unknown"
        },
        {
          "const": 1,
          "title": "Successful"
        },
        {
          "const": 2,
          "title": "Unsuccessful"
        }
      ]
    },
    "OutputInfoType": {
      "type": "integer",
      "format": "uint8"
    },
    "OutputInfoTypeMasks": {
      "anyOf": [
        {
          "const": 1,
          "title": "OrderNumber"
        },
        {
          "const": 2,
          "title": "LotNumber"
        },
        {
          "const": 4,
          "title": "SerialNumber"
        }
      ]
    },
    "OutputInformationDataType": {
      "type": "object",
      "properties": {
        "ItemNumber": {
          "type": [
            "string",
            "null"
          ]
        },
        "OutputInfo": {
          "type": "integer",
          "format": "uint8"
        },
        "OrderNumber": {
          "type": [
            "string",
            "null"
          ]
        },
        "LotNumber": {
          "type": [
            "string",
            "null"
          ]
        },
        "SerialNumber": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "BOMComponentInformationDataType": {
      "type": "object",
      "properties": {
        "Identification": {
          "$ref": "#/$defs/OutputInformationDataType"
        },
        "Quantity": {
          "type": "number",
          "format": "double"
        },
        "EngineeringUnits": {
          "$ref": "https://opcfoundation.org/schemas/UA/types.json#/$defs/EUInformation"
        }
      }
    },
    "BOMInformationDataType": {
      "type": "object",
      "properties": {
        "Identification": {
          "$ref": "#/$defs/OutputInformationDataType"
        },
        "ComponentInformation": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BOMComponentInformationDataType"
          }
        }
      }
    },
    "OutputPerformanceInfoDataType": {
      "type": "object",
      "properties": {
        "Identification": {
          "$ref": "#/$defs/OutputInformationDataType"
        },
        "StartTime": {
          "type": "string",
          "format": "date-time"
        },
        "EndTime": {
          "type": "string",
          "format": "date-time"
        },
        "Parameters": {
          "type": "array",
          "items": {
            "$ref": "https://opcfoundation.org/schemas/UA/ISA95-JOBCONTROL_V2/types.json#/$defs/ISA95ParameterDataType"
          }
        }
      }
    }
  }
}