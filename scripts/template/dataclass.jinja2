{% for decorator in decorators -%}
{{ decorator }}
{% endfor -%}
{%- set args = [] %}
{%- for k, v in (dataclass_arguments or {}).items() %}
    {%- if v is not none and v is not false %}
        {%- set _ = args.append(k ~ '=' ~ (v|pprint)) %}
    {%- endif %}
{%- endfor %}
{%- if args %}
@dataclass({{ args | join(', ') }})
{%- else %}
@dataclass
{%- endif %}
{%- if base_class %}
class {{ class_name }}({{ base_class }}):
{%- else %}
class {{ class_name }}:
{%- endif %}
{%- if description %}
    """
    {{ description | escape_docstring | indent(4) }}
    """
{%- endif %}
{%- if not fields and not description %}
    pass
{%- endif %}
{%- for field in fields -%}
    {%- if field.field %}
    {{ field.name }}: {{ field.type_hint }} = {{ field.field }}
    {%- else %}
    {{ field.name }}: {{ field.type_hint }}
    {%- if not (field.required or (field.represented_default == 'None' and field.strip_default_none))
            %} = {{ field.represented_default }}
    {%- endif -%}
    {%- endif %}
    {%- if field.docstring %}
    """
    {{ field.docstring | escape_docstring | indent(4) }}
    """
{%- if field.use_inline_field_description and not loop.last %}

{% endif %}
    {%- elif field.inline_field_docstring %}
    {{ field.inline_field_docstring }}
{%- if not loop.last %}

{% endif %}
    {%- endif %}
{%- endfor %}

    # mashumaro config class
    {%- if config_base_class %}
    class Config({{ config_base_class }}):
    {%- else %}
    class Config:
    {%- endif %}
    {%- if extensions is defined and extensions.get('x-response-type') %}
        response_type: str = "{{ extensions['x-response-type'] }}"
    {%- endif %}
    {%- if extensions is defined and extensions.get('x-cloudevent-type') %}
        cloudevent_type: str = "{{ extensions['x-cloudevent-type'] }}"
    {%- endif %}
    {%- if extensions is defined and extensions.get('x-cloudevent-dataschema') %}
        cloudevent_dataschema: str = "{{ extensions['x-cloudevent-dataschema'] }}"
    {%- endif %}
    {%- if extensions is defined and extensions.get('x-opc-ua-type') %}
        opcua_type: str = "{{ extensions['x-opc-ua-type'] }}"
    {%- endif %}
    {%- if extensions is defined and extensions.get('x-opc-ua-state-machine') %}
        opcua_state_machine: str = "{{ extensions['x-opc-ua-state-machine'] }}"
        opcua_state_machine_states: list[dict[str, Any]] = [
    {%- for key, value in extensions['x-opc-ua-state-machine']['states'].items() %}
            # {{ value['description'] }}
            {"name": "{{ key }}"{%- if value['subStateMachine'] %},
            "children": [
                {%- for sub_key, sub_value in value['subStateMachine']['states'].items() %}
                # {{ sub_value['description'] }}
                {"name": "{{ sub_key }}"},
                {%- endfor %}
            ],
            "transitions": [
                {%- for sub_key, sub_value in value['subStateMachine']['transitions'].items() %}
                # {{ sub_value['description'] }}
                {"trigger": "{{ value['cause'] if value['cause'] else key }}{{ sub_value['cause'] if sub_value['cause'] else sub_key }}", "source": "{{ sub_value['fromState'] }}", "dest": "{{ sub_value['toState'] }}"},
                {%- endfor %}
            ]{%- endif %}
            },
    {%- endfor %}
        ]
        opcua_state_machine_state_ids: dict[str, str] = {
    {%- for key, value in extensions['x-opc-ua-state-machine']['states'].items() %}
            "{{ key }}": "{{ value['number'] }}",{%- if value['subStateMachine'] %}
            {%- for sub_key, sub_value in value['subStateMachine']['states'].items() %}
            "{{ key }}_{{ sub_key }}": "{{ value['number'] }}_{{ sub_value['number'] }}",
            {%- endfor %}{%- endif %}
    {%- endfor %}
        }
        opcua_state_machine_transitions: list[dict[str, str]] = [
    {%- for key, value in extensions['x-opc-ua-state-machine']['transitions'].items() %}
            # {{ value['description'] }}
            {"trigger": "{{ value['cause'] if value['cause'] else key }}", "source": "{{ value['fromState'] }}", "dest": "{{ value['toState'] }}"},
    {%- endfor %}
        ]
        opcua_state_machine_effects: dict[str, str] = {
    {%- for key, value in extensions['x-opc-ua-state-machine']['transitions'].items() %}
            "{{ value['cause'] if value['cause'] else key }}": "{{ value['effect'] if value['effect'] else None}}",
    {%- endfor %}
        }
    {%- endif %}
        aliases: dict[str, str] = {
    {%- for field in fields %}
            "{{ field.name }}": "{{ field.alias }}",
    {%- endfor %}
        }